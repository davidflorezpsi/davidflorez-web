---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <p class="copyright">© {year} David Flórez · Psicólogo Clínico T.P. 205129</p>
    <p class="location">Bogotá, Colombia · Consulta online Latinoamérica y España</p>
    <nav class="footer-links" aria-label="Links del pie de página">
      <a href="/privacidad">Política de privacidad</a>
      <a href="https://instagram.com/ps.davidflorez" aria-label="Instagram" target="_blank" rel="noopener noreferrer">Instagram</a>
      <a href="#" aria-label="TikTok" target="_blank" rel="noopener noreferrer">TikTok</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    background: #003346;
    color: #fff;
    padding: 3rem 0;
    text-align: center;
    border-top: 1px solid #05a3d4;
  }

  .copyright {
    font-size: 0.9rem;
    margin-bottom: 0.4rem;
  }

  .location {
    font-size: 0.85rem;
    opacity: 0.7;
    margin-bottom: 1.5rem;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .footer-links a {
    font-size: 0.85rem;
    color: #05a3d4;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: #fff;
  }
</style>
